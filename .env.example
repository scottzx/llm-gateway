# Gateway 配置文件

# Gateway 服务端口
PORT=3012

# 目标转发 URL（固定的转发目标）
# 示例: TARGET_URL=https://api-inference.modelscope.cn
TARGET_URL=https://open.bigmodel.cn/api/anthropic

# API 认证 Token
# 示例: API_TOKEN=your-api-token-here
API_TOKEN=your-api-token-here

# 请求超时时间（毫秒）
TIMEOUT=60000

# 是否开启请求日志
LOG_ENABLED=true

# 聊天日志目录
CHAT_LOG_DIR=logs

# 是否启用聊天日志
CHAT_LOG_ENABLED=true

# ===== 数据库日志配置 =====

# 是否启用数据库日志（SQLite）
DB_LOG_ENABLED=true

# 数据库文件路径
DB_LOG_PATH=./data/chat-logs.db

# 日志保留天数（7天）
LOG_RETENTION_DAYS=7

# 清理任务间隔（小时）
CLEANUP_INTERVAL_HOURS=1

# ModelScope API 配置（用于翻译服务）
MODELSCOPE_API_ENDPOINT=https://api-inference.modelscope.cn/v1/chat/completions
TRANSLATION_API_TOKEN=your-modelscope-token-here
TRANSLATION_MODEL=Qwen/Qwen3.5-397B-A17B
TRANSLATION_TIMEOUT=30000
